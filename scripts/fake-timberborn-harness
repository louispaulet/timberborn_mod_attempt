#!/usr/bin/env python3
import argparse
import json
import sys
import time
import urllib.parse
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer


API_PREFIX = "/api/ai-harness"


def normalize(value):
    return "".join(character for character in (value or "").lower() if character.isalnum())


def response(command, command_id, data=None, error=None):
    return {
        "ok": error is None,
        "command": command,
        "commandId": command_id,
        "data": data if error is None else None,
        "error": error,
    }


def status_code(payload):
    if payload["ok"]:
        return 200
    return 404 if payload["error"] == "Unknown AI Harness command." else 400


def option(button, label, kind, payload=""):
    return {
        "button": button,
        "label": label,
        "kind": kind,
        "payload": payload,
    }


def validate_menu(question, options):
    if not question or not question.strip():
        return "Interaction menu requires a question."
    if len(options) != 4:
        return "Interaction menu must provide exactly four options."

    normalized = [{"kind": normalize(item["kind"]), "label": normalize(item["label"])} for item in options]
    if any(not item["label"] for item in normalized):
        return "Interaction menu option labels cannot be empty."

    confirmation = any(item["kind"] == "confirm" for item in normalized)
    has_tool = any(item["kind"] == "tool" for item in normalized)
    has_navigation = any(item["kind"] in ("menu", "nav", "navigate") for item in normalized)
    has_back_or_no = any(
        item["kind"] in ("back", "cancel", "no")
        or "back" in item["label"]
        or "cancel" in item["label"]
        or item["label"] == "no"
        for item in normalized
    )
    has_yes = any(item["kind"] == "yes" or item["label"] == "yes" or item["label"].startswith("yes") for item in normalized)
    has_no = any(item["kind"] == "no" or item["label"] == "no" or item["label"].startswith("no") for item in normalized)

    if confirmation and (not has_yes or not has_no):
        return "Confirmation menus must include yes and no choices."
    if not confirmation and (not has_tool or not has_navigation or not has_back_or_no):
        return "Non-confirmation menus must include at least one tool option, one menu/navigation option, and one back/cancel/no option."
    return ""


class FakeHarnessState:
    def __init__(self):
        self.command_counter = 0
        self.executed_commands = 0
        self.speed = 1
        self.context = "Fake"
        self.settlement = ""
        self.interaction = self.default_interaction()

    def command_id(self, command):
        self.command_counter += 1
        return f"{command}-fake-{self.command_counter:04d}"

    def ok(self, command, data):
        self.executed_commands += 1
        return response(command, self.command_id(command), data=data)

    def fail(self, command, error):
        self.executed_commands += 1
        return response(command, self.command_id(command), error=error)

    def default_interaction(self):
        return {
            "status": "idle",
            "interactionId": "",
            "menuId": "",
            "question": "Press Ask AI to request contextual help.",
            "topic": "",
            "source": "",
            "skillId": "general",
            "menuPath": "root",
            "contextHash": "none",
            "replayKey": "0-1-0-general-root-none",
            "revision": 0,
            "refreshRequests": 0,
            "lastButton": 0,
            "lastAnswer": {},
            "lastTool": {"name": "", "ok": False, "summary": ""},
            "lastError": "",
            "options": [
                option(1, "Ask AI", "menu", "root"),
                option(2, "Water Check", "tool", "timberborn_water_readiness"),
                option(3, "Build Tips", "menu", "building.pathing"),
                option(4, "No", "cancel", ""),
            ],
        }

    def bump(self):
        self.interaction["revision"] += 1

    def replay_key(self):
        return "-".join(
            sanitize_replay_part(part)
            for part in ("0.1.0", self.interaction["skillId"], self.interaction["menuPath"], self.interaction["contextHash"])
        )

    def snapshot(self):
        self.interaction["replayKey"] = self.replay_key()
        return dict(self.interaction)

    def status(self):
        return {
            "mod": "AI Harness",
            "id": "LouisPaulet.AiHarness",
            "context": self.context,
            "api": API_PREFIX,
            "modPath": "/tmp/fake-timberborn-harness/AiHarness",
            "pendingCommands": 0,
            "executedCommands": self.executed_commands,
            "speed": self.speed,
            "dayNumber": 3,
            "hoursPassedToday": 6.5,
            "camera": {"target": {"x": 32, "y": 0, "z": 29}, "zoom": 0.4},
            "settlement": self.settlement,
        }

    def commands(self):
        return {
            "basePath": API_PREFIX,
            "commands": [
                "GET /api/ai-harness/status",
                "GET /api/ai-harness/commands",
                "GET|POST /api/ai-harness/new-game?settlement=...&map=...&faction=...",
                "GET|POST /api/ai-harness/interaction/request?topic=...",
                "GET|POST /api/ai-harness/interaction/show?interactionId=...&menuId=...&question=...&label1=...",
                "GET|POST /api/ai-harness/interaction/answer?button=1|2|3|4",
                "GET /api/ai-harness/game-context",
                "GET /api/ai-harness/water-readiness",
                "GET /api/ai-harness/buildings?query=...",
                "GET|POST /api/ai-harness/place-building?template=water_tank",
            ],
        }

    def game_context(self):
        return {
            "scope": "global",
            "dayNumber": 3,
            "hoursPassedToday": 6.5,
            "speed": self.speed,
            "camera": {"target": {"x": 32, "y": 0, "z": 29}, "zoom": 0.4},
            "population": {"adults": 3, "children": 1, "beavers": 4, "bots": 0, "total": 4},
            "districts": [{"population": {"adults": 3, "children": 1, "beavers": 4, "bots": 0, "total": 4}}],
        }

    def resource_summary(self, requested_good):
        good_id = "Water" if normalize(requested_good) in ("", "water") else requested_good
        return {
            "requestedGood": requested_good,
            "goodId": good_id,
            "availableStock": 24,
            "allStock": 30,
            "totalCapacity": 80,
            "fillRate": 0.3,
            "stockpiledStock": 24,
            "bufferedOutputStock": 0,
            "carriedToStockpilesStock": 0,
            "carriedToProcessors": 0,
            "stockUnderProcessing": 0,
            "bufferedInput": 0,
        }

    def water_readiness(self):
        return {
            "goodId": "Water",
            "population": {"adults": 3, "children": 1, "beavers": 4, "bots": 0, "total": 4},
            "availableWater": 24,
            "allWater": 30,
            "waterCapacity": 80,
            "waterFillRate": 0.3,
            "waterPerBeaver": 6.0,
            "waterCapacityPerBeaver": 20.0,
            "daysOfWater": 3.0,
            "rule": "daysOfWater = availableWater / max(1, beavers * 2)",
            "recommendation": "Water storage looks acceptable for the current population.",
        }

    def buildings(self, query):
        templates = [
            {
                "templateName": "Path.Folktails",
                "blueprintName": "Path",
                "displayNameLocKey": "Path.DisplayName",
                "descriptionLocKey": "basic path",
                "toolGroupId": "Paths",
                "toolOrder": 1,
            },
            {
                "templateName": "SmallTank.Folktails",
                "blueprintName": "SmallTank",
                "displayNameLocKey": "WaterTankSmall.DisplayName",
                "descriptionLocKey": "small water storage",
                "toolGroupId": "Storage",
                "toolOrder": 10,
            },
            {
                "templateName": "Stairs.Folktails",
                "blueprintName": "Stairs",
                "displayNameLocKey": "Stairs.DisplayName",
                "descriptionLocKey": "stairs",
                "toolGroupId": "Paths",
                "toolOrder": 20,
            },
            {
                "templateName": "Platform.Folktails",
                "blueprintName": "Platform",
                "displayNameLocKey": "Platform.DisplayName",
                "descriptionLocKey": "platform",
                "toolGroupId": "Platforms",
                "toolOrder": 30,
            },
        ]
        normalized_query = normalize(query)
        if normalized_query:
            templates = [
                template
                for template in templates
                if normalized_query
                in normalize(
                    " ".join(
                        [
                            template["templateName"],
                            template["blueprintName"],
                            template["displayNameLocKey"],
                            template["descriptionLocKey"],
                            template["toolGroupId"],
                        ]
                    )
                )
            ]
        return {"query": query or "", "buildings": templates[:100]}

    def place_building(self, params):
        template = params.get("template", ["water_tank"])[0] or "water_tank"
        aliases = {
            "water_tank": "SmallTank.Folktails",
            "watertank": "SmallTank.Folktails",
            "tank": "SmallTank.Folktails",
            "path": "Path.Folktails",
            "stairs": "Stairs.Folktails",
            "platform": "Platform.Folktails",
            "SmallTank.Folktails": "SmallTank.Folktails",
        }
        resolved = aliases.get(template)
        if resolved is None:
            return self.fail("place-building", f"Building template not found: {template}")

        placement = {
            "x": int(params.get("x", ["32"])[0] or 32),
            "y": int(params.get("y", ["29"])[0] or 29),
            "z": int(params.get("z", ["3"])[0] or 3),
            "orientation": params.get("orientation", ["Cw0"])[0] or "Cw0",
            "flipped": (params.get("flipped", ["false"])[0] or "false").lower() == "true",
        }
        return self.ok(
            "place-building",
            {
                "template": {
                    "templateName": resolved,
                    "blueprintName": resolved.split(".")[0],
                    "displayNameLocKey": "",
                    "descriptionLocKey": "",
                    "toolGroupId": "",
                    "toolOrder": 0,
                },
                "placement": placement,
                "placedAs": "construction-site",
                "searched": not all(key in params for key in ("x", "y", "z")),
                "searchRadius": int(params.get("searchRadius", ["16"])[0] or 16),
            },
        )


def sanitize_replay_part(value):
    sanitized = "".join(character if character.isalnum() else "-" for character in (value or "").strip().lower()).strip("-")
    return sanitized or "none"


class Handler(BaseHTTPRequestHandler):
    state = FakeHarnessState()

    def do_GET(self):
        self.handle_request()

    def do_POST(self):
        self.handle_request()

    def log_message(self, format, *args):
        return

    def handle_request(self):
        parsed = urllib.parse.urlparse(self.path)
        params = urllib.parse.parse_qs(parsed.query)
        path = parsed.path.rstrip("/")
        command = path[len(API_PREFIX) :].strip("/").lower() if path.startswith(API_PREFIX) else "unknown"
        if command == "":
            command = "status"

        try:
            payload = self.dispatch(command, params)
        except Exception as error:
            payload = self.state.fail(command, str(error))

        body = json.dumps(payload, sort_keys=True).encode("utf-8")
        self.send_response(status_code(payload))
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def dispatch(self, command, params):
        state = self.state
        if command == "status":
            return state.ok("status", state.status())
        if command == "commands":
            return state.ok("commands", state.commands())
        if command == "new-game":
            state.context = "Game"
            state.settlement = params.get("settlement", [f"FakeHarness-{int(time.time())}"])[0]
            return state.ok(
                "new-game",
                {
                    "settlement": state.settlement,
                    "map": params.get("map", ["Diorama"])[0],
                    "faction": params.get("faction", ["Folktails"])[0],
                },
            )
        if command == "speed":
            value = int(params.get("value", ["1"])[0])
            if value < 0 or value > 3:
                return state.fail("speed", "Speed value must be one of 0, 1, 2, or 3.")
            current_speed_before = state.speed
            state.speed = value
            return state.ok("speed", {"requestedSpeed": value, "currentSpeedBefore": current_speed_before, "currentSpeed": state.speed})
        if command == "interaction":
            return state.ok("interaction", state.snapshot())
        if command == "interaction/clear":
            state.interaction = state.default_interaction()
            state.bump()
            return state.ok("interaction-clear", state.snapshot())
        if command == "interaction/request":
            topic = params.get("topic", ["current situation"])[0]
            source = params.get("source", ["api"])[0]
            state.interaction.update(
                {
                    "status": "requested",
                    "interactionId": f"interaction-fake-{int(time.time() * 1000)}",
                    "menuId": "",
                    "question": f"AI help requested: {topic}" if topic.strip() else "AI help requested. Waiting for Pi.",
                    "topic": topic,
                    "source": source,
                    "skillId": "general",
                    "menuPath": "root",
                    "contextHash": "none",
                    "lastError": "",
                    "lastButton": 0,
                    "lastAnswer": {},
                    "lastTool": {"name": "", "ok": False, "summary": ""},
                    "refreshRequests": 0,
                    "options": [
                        option(1, "Waiting", "menu", "waiting"),
                        option(2, "Status", "tool", "timberborn_status"),
                        option(3, "Context", "tool", "timberborn_game_context"),
                        option(4, "Cancel", "cancel", ""),
                    ],
                }
            )
            state.bump()
            return state.ok("interaction-request", state.snapshot())
        if command == "interaction/refresh":
            state.interaction.update(
                {
                    "status": "refreshRequested",
                    "menuId": "",
                    "question": "Choice refresh requested. Waiting for Pi to offer a different path.",
                    "lastError": "",
                    "lastButton": 0,
                    "lastAnswer": {},
                    "lastTool": {"name": "", "ok": False, "summary": ""},
                    "refreshRequests": int(state.interaction.get("refreshRequests") or 0) + 1,
                    "options": [
                        option(1, "Refreshing", "menu", "refreshing"),
                        option(2, "Status", "tool", "timberborn_status"),
                        option(3, "Context", "tool", "timberborn_game_context"),
                        option(4, "Cancel", "cancel", ""),
                    ],
                }
            )
            if not state.interaction["interactionId"]:
                state.interaction["interactionId"] = f"interaction-fake-{int(time.time() * 1000)}"
            state.bump()
            return state.ok("interaction-refresh", state.snapshot())
        if command == "interaction/show":
            options = [
                option(
                    index,
                    params.get(f"label{index}", [""])[0],
                    params.get(f"kind{index}", ["menu"])[0],
                    params.get(f"payload{index}", [""])[0],
                )
                for index in range(1, 5)
            ]
            validation_error = validate_menu(params.get("question", [""])[0], options)
            if validation_error:
                state.interaction["lastError"] = validation_error
                state.bump()
                return state.fail("interaction-show", validation_error)
            state.interaction.update(
                {
                    "status": "menuShown",
                    "interactionId": params.get("interactionId", [state.interaction["interactionId"] or f"interaction-fake-{int(time.time() * 1000)}"])[0],
                    "menuId": params.get("menuId", ["pi-menu"])[0] or "pi-menu",
                    "question": params.get("question", [""])[0],
                    "skillId": params.get("skillId", ["general"])[0] or "general",
                    "menuPath": params.get("menuPath", ["root"])[0] or "root",
                    "contextHash": params.get("contextHash", ["none"])[0] or "none",
                    "lastError": "",
                    "lastButton": 0,
                    "lastAnswer": {},
                    "lastTool": {"name": "", "ok": False, "summary": ""},
                    "options": options,
                }
            )
            state.bump()
            return state.ok("interaction-show", state.snapshot())
        if command == "interaction/answer":
            button = int(params.get("button", ["0"])[0])
            if button < 1 or button > 4:
                return state.fail("interaction-answer", "Button must be one of 1, 2, 3, or 4.")
            selected = state.interaction["options"][button - 1]
            state.interaction["lastButton"] = button
            state.interaction["lastAnswer"] = selected
            state.interaction["lastError"] = ""
            state.interaction["status"] = "toolRequested" if selected["kind"].lower() == "tool" else "answerSubmitted"
            state.bump()
            return state.ok("interaction-answer", state.snapshot())
        if command == "interaction/tool-result":
            tool = params.get("tool", [""])[0]
            if not tool.strip():
                return state.fail("interaction-tool-result", "Missing required query parameter: tool.")
            ok = (params.get("ok", ["false"])[0] or "false").lower() == "true"
            summary = params.get("summary", [""])[0]
            state.interaction["status"] = "toolCompleted"
            state.interaction["lastTool"] = {"name": tool, "ok": ok, "summary": summary}
            state.interaction["question"] = summary or f"Tool completed: {tool}"
            state.interaction["lastError"] = "" if ok else summary
            state.bump()
            return state.ok("interaction-tool-result", state.snapshot())
        if command == "game-context":
            return state.ok("game-context", state.game_context())
        if command == "resource-summary":
            return state.ok("resource-summary", state.resource_summary(params.get("good", ["water"])[0]))
        if command == "water-readiness":
            return state.ok("water-readiness", state.water_readiness())
        if command == "buildings":
            return state.ok("buildings", state.buildings(params.get("query", [""])[0]))
        if command == "place-building":
            return state.place_building(params)

        return state.fail(command, "Unknown AI Harness command.")


def main():
    parser = argparse.ArgumentParser(description="Run a fake Timberborn AI Harness server for fast local tests.")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=18080)
    args = parser.parse_args()

    server = ThreadingHTTPServer((args.host, args.port), Handler)

    print(f"Fake Timberborn AI Harness listening on http://{args.host}:{args.port}", flush=True)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    sys.exit(main())
