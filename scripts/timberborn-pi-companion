#!/usr/bin/env python3
import argparse
import json
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request


DEFAULT_BASE_URL = "http://localhost:8080"
TIMBERBORN_PROCESS_NAME = "Timberborn"


def is_timberborn_running():
    return subprocess.run(
        ["pgrep", "-x", TIMBERBORN_PROCESS_NAME],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    ).returncode == 0


def focus_timberborn_if_running():
    if not is_timberborn_running():
        return False

    subprocess.run(
        [
            "osascript",
            "-e",
            'tell application "System Events" to set frontmost of process "Timberborn" to true',
        ],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    return True


def request_json(base_url, path, params=None, method="GET"):
    if not focus_timberborn_if_running():
        return {"ok": False, "error": "Timberborn is not running; refusing to poll or activate it."}
    time.sleep(0.15)
    query = urllib.parse.urlencode({k: v for k, v in (params or {}).items() if v is not None})
    url = base_url.rstrip("/") + path
    if query:
        url = url + "?" + query

    request = urllib.request.Request(url, method=method)
    try:
        with urllib.request.urlopen(request, timeout=8) as response:
            return json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as error:
        body = error.read().decode("utf-8")
        try:
            return json.loads(body)
        except json.JSONDecodeError:
            return {"ok": False, "error": f"HTTP {error.code}: {body}"}
    except urllib.error.URLError as error:
        return {"ok": False, "error": f"Could not reach Timberborn AI Harness at {base_url}: {error.reason}"}


def show_menu(base_url, interaction_id, menu_id, question, skill_id, menu_path, context_hash, options):
    if len(options) != 4:
        raise ValueError("Menus must have exactly four options.")

    params = {
        "interactionId": interaction_id,
        "menuId": menu_id,
        "question": question,
        "skillId": skill_id,
        "menuPath": menu_path,
        "contextHash": context_hash,
    }
    for index, option in enumerate(options, start=1):
        params[f"label{index}"] = option["label"]
        params[f"kind{index}"] = option["kind"]
        params[f"payload{index}"] = option.get("payload", "")
    return request_json(base_url, "/api/ai-harness/interaction/show", params, method="POST")


def read_refresh_count(data):
    try:
        return max(0, int(data.get("refreshRequests") or 0))
    except (TypeError, ValueError):
        return 0


def refresh_suffix(refresh_count):
    return "" if refresh_count <= 0 else f"-refresh-{refresh_count}"


def refresh_context(refresh_count):
    return "live" if refresh_count <= 0 else f"live-refresh-{refresh_count}"


def root_menu(base_url, interaction_id, refresh_count=0):
    variants = [
        (
            "Pi: what should I inspect for this settlement?",
            [
                {"label": "Water readiness", "kind": "tool", "payload": "timberborn_water_readiness"},
                {"label": "Game context", "kind": "tool", "payload": "timberborn_game_context"},
                {"label": "Build tips", "kind": "menu", "payload": "building.pathing"},
                {"label": "No", "kind": "no", "payload": ""},
            ],
        ),
        (
            "Pi: want a different angle?",
            [
                {"label": "Settlement snapshot", "kind": "tool", "payload": "timberborn_game_context"},
                {"label": "Water risk", "kind": "tool", "payload": "timberborn_water_readiness"},
                {"label": "Pathing ideas", "kind": "menu", "payload": "building.pathing"},
                {"label": "No", "kind": "no", "payload": ""},
            ],
        ),
        (
            "Pi: choose a new thread to pull.",
            [
                {"label": "Harness status", "kind": "tool", "payload": "timberborn_status"},
                {"label": "Build route", "kind": "menu", "payload": "building.pathing"},
                {"label": "Water numbers", "kind": "tool", "payload": "timberborn_water_readiness"},
                {"label": "No", "kind": "no", "payload": ""},
            ],
        ),
    ]
    question, options = variants[refresh_count % len(variants)]
    return show_menu(
        base_url,
        interaction_id,
        "pi-root" + refresh_suffix(refresh_count),
        question,
        "water.storage-readiness",
        "root",
        refresh_context(refresh_count),
        options,
    )


def build_tips_menu(base_url, interaction_id, refresh_count=0):
    variants = [
        (
            "Pi: building tips. What should I help with next?",
            [
                {"label": "Check context", "kind": "tool", "payload": "timberborn_game_context"},
                {"label": "Water readiness", "kind": "tool", "payload": "timberborn_water_readiness"},
                {"label": "Root menu", "kind": "menu", "payload": "root"},
                {"label": "Back", "kind": "back", "payload": "root"},
            ],
        ),
        (
            "Pi: another building angle?",
            [
                {"label": "Map context", "kind": "tool", "payload": "timberborn_game_context"},
                {"label": "Water constraint", "kind": "tool", "payload": "timberborn_water_readiness"},
                {"label": "Root menu", "kind": "menu", "payload": "root"},
                {"label": "Back", "kind": "back", "payload": "root"},
            ],
        ),
        (
            "Pi: want to pivot the build plan?",
            [
                {"label": "Harness status", "kind": "tool", "payload": "timberborn_status"},
                {"label": "Water first", "kind": "tool", "payload": "timberborn_water_readiness"},
                {"label": "Root menu", "kind": "menu", "payload": "root"},
                {"label": "Back", "kind": "back", "payload": "root"},
            ],
        ),
    ]
    question, options = variants[refresh_count % len(variants)]
    return show_menu(
        base_url,
        interaction_id,
        "building-pathing" + refresh_suffix(refresh_count),
        question,
        "building.pathing",
        "building/pathing",
        refresh_context(refresh_count),
        options,
    )


def result_menu(base_url, interaction_id, question, refresh_count=0):
    variants = [
        [
            {"label": "Water readiness", "kind": "tool", "payload": "timberborn_water_readiness"},
            {"label": "Game context", "kind": "tool", "payload": "timberborn_game_context"},
            {"label": "Build tips", "kind": "menu", "payload": "building.pathing"},
            {"label": "No", "kind": "no", "payload": ""},
        ],
        [
            {"label": "Settlement snapshot", "kind": "tool", "payload": "timberborn_game_context"},
            {"label": "Pathing ideas", "kind": "menu", "payload": "building.pathing"},
            {"label": "Water risk", "kind": "tool", "payload": "timberborn_water_readiness"},
            {"label": "No", "kind": "no", "payload": ""},
        ],
        [
            {"label": "Harness status", "kind": "tool", "payload": "timberborn_status"},
            {"label": "Water numbers", "kind": "tool", "payload": "timberborn_water_readiness"},
            {"label": "Build route", "kind": "menu", "payload": "building.pathing"},
            {"label": "No", "kind": "no", "payload": ""},
        ],
    ]
    return show_menu(
        base_url,
        interaction_id,
        "pi-result" + refresh_suffix(refresh_count),
        question,
        "general",
        "result",
        refresh_context(refresh_count),
        variants[refresh_count % len(variants)],
    )


def refreshed_menu(base_url, data):
    interaction_id = data["interactionId"]
    refresh_count = read_refresh_count(data)
    menu_path = (data.get("menuPath") or "root").lower()
    if menu_path.startswith("building"):
        return build_tips_menu(base_url, interaction_id, refresh_count)
    if menu_path == "result":
        return result_menu(base_url, interaction_id, "Pi: refreshed choices. Which path feels better?", refresh_count)
    return root_menu(base_url, interaction_id, refresh_count)


def summarize_water(payload):
    data = payload.get("data") or {}
    return (
        f"Pi result: {data.get('recommendation', 'water checked')} "
        f"Water {data.get('availableWater', '?')}/{data.get('waterCapacity', '?')}, "
        f"{data.get('daysOfWater', '?')} days for {((data.get('population') or {}).get('beavers', '?'))} beavers."
    )


def summarize_context(payload):
    data = payload.get("data") or {}
    population = data.get("population") or {}
    return (
        f"Pi result: day {data.get('dayNumber', '?')}, speed {data.get('speed', '?')}, "
        f"{population.get('beavers', '?')} beavers, scope {data.get('scope', '?')}."
    )


def run_tool(base_url, tool):
    if tool == "timberborn_water_readiness":
        payload = request_json(base_url, "/api/ai-harness/water-readiness")
        return payload, summarize_water(payload)
    if tool == "timberborn_game_context":
        payload = request_json(base_url, "/api/ai-harness/game-context")
        return payload, summarize_context(payload)
    if tool == "timberborn_status":
        payload = request_json(base_url, "/api/ai-harness/status")
        data = payload.get("data") or {}
        return payload, f"Pi result: harness status ok, day {data.get('dayNumber', '?')}, speed {data.get('speed', '?')}."
    payload = {"ok": False, "error": f"Unsupported companion tool: {tool}"}
    return payload, payload["error"]


def tick(base_url, seen_revision):
    state = request_json(base_url, "/api/ai-harness/interaction")
    if not state.get("ok"):
        print("watch: " + json.dumps(state, sort_keys=True), flush=True)
        return seen_revision

    data = state["data"]
    revision = data["revision"]
    if revision == seen_revision:
        return seen_revision

    status = data["status"]
    interaction_id = data["interactionId"]
    print(f"watch: revision={revision} status={status} button={data.get('lastButton')} menu={data.get('menuId')}", flush=True)

    if status == "requested":
        print(json.dumps(root_menu(base_url, interaction_id), sort_keys=True), flush=True)
    elif status == "refreshRequested":
        print(json.dumps(refreshed_menu(base_url, data), sort_keys=True), flush=True)
    elif status == "answerSubmitted":
        answer = data.get("lastAnswer") or {}
        payload = answer.get("payload", "")
        refresh_count = read_refresh_count(data)
        if answer.get("kind") in ("menu", "nav", "navigate") and payload == "building.pathing":
            print(json.dumps(build_tips_menu(base_url, interaction_id, refresh_count), sort_keys=True), flush=True)
        elif answer.get("kind") in ("menu", "nav", "navigate"):
            print(json.dumps(root_menu(base_url, interaction_id, refresh_count), sort_keys=True), flush=True)
    elif status == "toolRequested":
        answer = data.get("lastAnswer") or {}
        tool = answer.get("payload", "")
        refresh_count = read_refresh_count(data)
        payload, summary = run_tool(base_url, tool)
        ok = bool(payload.get("ok"))
        print(json.dumps(request_json(
            base_url,
            "/api/ai-harness/interaction/tool-result",
            {"tool": tool, "ok": str(ok).lower(), "summary": summary},
            method="POST",
        ), sort_keys=True), flush=True)
        print(json.dumps(result_menu(base_url, interaction_id, summary, refresh_count), sort_keys=True), flush=True)

    return revision


def main():
    parser = argparse.ArgumentParser(description="Run a small polling companion for the Timberborn four-button Pi HUD.")
    parser.add_argument("--base-url", default=DEFAULT_BASE_URL)
    parser.add_argument("--poll-seconds", type=float, default=1.0)
    parser.add_argument("--once", action="store_true", help="Process one state transition and exit.")
    args = parser.parse_args()

    if not is_timberborn_running():
        print("watch: Timberborn is not running; companion loop refused to start.", file=sys.stderr, flush=True)
        return 2

    seen_revision = -1
    while True:
        if not is_timberborn_running():
            print("watch: Timberborn is no longer running; companion loop exiting.", file=sys.stderr, flush=True)
            return 2
        try:
            seen_revision = tick(args.base_url, seen_revision)
        except KeyboardInterrupt:
            return 130
        except Exception as error:
            print(f"watch error: {error}", file=sys.stderr, flush=True)
        if args.once:
            return 0
        time.sleep(args.poll_seconds)


if __name__ == "__main__":
    sys.exit(main())
